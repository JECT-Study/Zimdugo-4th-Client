{
  "name": "storybook",
  "private": true,
  "type": "module",
  "scripts": {
    "i18n:compile": "paraglide-js compile --project ../../packages/i18n/project.inlang --outdir ./.storybook/paraglide",
    "dev": "paraglide-js compile --project ../../packages/i18n/project.inlang --outdir ./.storybook/paraglide && storybook dev -p 6006",
    "build": "paraglide-js compile --project ../../packages/i18n/project.inlang --outdir ./.storybook/paraglide && storybook build"
  },
  "dependencies": {
    "@repo/ui": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "2.13.1",
    "@storybook/react-vite": "^10.1.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vanilla-extract/vite-plugin": "^5.1.4",
    "storybook": "^10.1.10",
    "typescript": "^5.7.2",
    "vite": "^7.1.7"
  }
}
